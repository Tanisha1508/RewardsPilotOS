DATABASE_URL=            # Supabase Postgres, e.g. postgresql+psycopg://user:pass@host:5432/postgres
SUPABASE_URL=
SUPABASE_ANON_KEY=       # frontend
# Legacy HS256 projects only (ADR-014). If your project has migrated to JWT
# Signing Keys — Settings > JWT Keys shows a current key of type ECC (P-256) —
# leave this blank: tokens are verified against the project's JWKS endpoint,
# derived from SUPABASE_URL. Fill it in only if the current key is
# "Legacy HS256 (Shared Secret)".
SUPABASE_JWT_SECRET=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Cross-provider LLM fallback (ADR-018), free tier / open models. Optional:
# with no key the fallback chain is Gemini-only (primary model -> second Gemini
# model). Set this to add Groq as the last resort, covering a Gemini-wide outage.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
REDIS_URL=               # Upstash
CHROMA_PERSIST_DIR=data/embeddings
BACKEND_URL=             # for frontend
FRONTEND_URL=            # CORS allowlist
ENV=development

# Integration tests only (added D2, ADR-013). Deliberately separate from
# DATABASE_URL: the integration suite creates and drops the entire schema, so it
# must never run against whatever database happens to be configured. Tests skip
# when it is unset.
#
# Use a local Postgres, not Supabase. The suite migrates up and down on every
# run; free Supabase projects pause after ~7 days idle, which surfaces as a test
# failure that looks like a code bug; and Supabase branching is a Pro-plan
# feature, which the free-tier-only constraint rules out.
#   brew install postgresql@16 && brew services start postgresql@16
#   createdb rewardspilot_test
#   TEST_DATABASE_URL=postgresql+psycopg://$USER@localhost:5432/rewardspilot_test
TEST_DATABASE_URL=
