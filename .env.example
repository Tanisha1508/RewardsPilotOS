DATABASE_URL=            # Supabase Postgres, e.g. postgresql+psycopg://user:pass@host:5432/postgres
SUPABASE_URL=
SUPABASE_ANON_KEY=       # frontend
SUPABASE_JWT_SECRET=     # backend verification
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
REDIS_URL=               # Upstash
CHROMA_PERSIST_DIR=data/embeddings
BACKEND_URL=             # for frontend
FRONTEND_URL=            # CORS allowlist
ENV=development

# Integration tests only (added D2, ADR-013). Deliberately separate from
# DATABASE_URL: the integration suite creates and drops the entire schema, so it
# must never run against whatever database happens to be configured. Point it at
# a Supabase branch or a throwaway Postgres. Tests skip when it is unset.
TEST_DATABASE_URL=
